    "@codemirror/view": "^6.38.6",
    "@lezer/common": "^1.3.0",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.2",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "@uiw/react-codemirror": "^4.25.2",
    "@xyflow/react": "^12.10.1",
    "clsx": "^2.1.1",
    "katex": "^0.16.38",
