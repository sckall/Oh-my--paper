    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "5.4.296",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "y-codemirror.next": "^0.3.5",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30"
