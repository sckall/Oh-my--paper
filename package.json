{
  "name": "oh-my-paper",
  "private": true,
  "version": "0.2.2",
  "type": "module",
  "scripts": {
    "sidecar:install": "npm install --prefix sidecar --no-audit --no-fund",
    "sidecar:build": "npm run --prefix sidecar build",
    "sidecar:stage": "node scripts/stage-sidecar.mjs",
    "skills:research:sync": "node scripts/sync-research-skills.mjs sync",
    "skills:research:check": "node scripts/sync-research-skills.mjs check",
    "skills:research:report": "node scripts/sync-research-skills.mjs report",
    "dev": "npm run sidecar:install && npm run sidecar:build && npm run sidecar:stage && vite --port 5173 --strictPort",
    "build": "npm run sidecar:install && npm run sidecar:build && npm run sidecar:stage && tsc -b && vite build",
    "tauri": "tauri",
    "version:bump": "node scripts/bump-version.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
